# ============================================
# Context.ai Frontend — Environment Variables
# ============================================
# Copia este archivo a .env.local y rellena los valores reales:
#   cp env.local.example .env.local
#
# Variables prefijadas con NEXT_PUBLIC_ se exponen al navegador.
# El resto son solo del lado del servidor.
# ============================================

# ---- Application ----
NODE_ENV=development
PORT=3000

# ---- Auth0 / NextAuth.js ----
# Usadas por NextAuth.js v5 (src/auth.ts)
#
# AUTH_SECRET: secreto para cifrar las sesiones de NextAuth.js v5. REQUERIDO.
# Genera con: openssl rand -hex 32
AUTH_SECRET=a-long-random-string-for-nextauth-session-encryption

AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER=https://your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.contextai.com

# AUTH0_SECRET: secreto de compatibilidad para la configuración legacy (src/lib/auth0.config.ts).
# Puede ser el mismo valor que AUTH_SECRET.
AUTH0_SECRET=same-value-as-AUTH_SECRET
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com

# Logout completo (limpia la sesión de Auth0).
# Añade la URL de tu app a Auth0 Dashboard → Applications → Allowed Logout URLs.
# NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id

# ---- API Connection ----
# URL del backend incluyendo el prefijo de versión. REQUERIDO.
# ⚠️  No omitir el /api/v1 — sin él, todas las llamadas a la API devolverán 404.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Clave interna para comunicación servidor-a-servidor (sincronización de usuarios).
# ⚠️  DEBE SER EXACTAMENTE LA MISMA que INTERNAL_API_KEY en context-ai-api/.env
# Genera con: openssl rand -hex 32  (una sola vez, comparte el valor en ambos .env)
INTERNAL_API_KEY=your-internal-api-key

# ---- Testing (opcional) ----
# Activar SOLO en entornos de test/CI para omitir Auth0 en tests E2E.
# NUNCA activar en producción — hay una verificación de seguridad que lanzará error.
# E2E_BYPASS_AUTH=false
